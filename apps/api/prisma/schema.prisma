generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum StaffRole {
  SUPER_ADMIN
  ADMIN
  MODERATOR
  EDITOR
  ANALYST
}

enum UserStatus {
  ACTIVE
  SUSPENDED
}

enum IncidentStatus {
  NEW
  UNDER_REVIEW
  ACTIONED
  CLOSED
  REJECTED
}

enum SubmissionLanguage {
  ha
  en
}

enum IncidentSeverity {
  LOW
  MEDIUM
  HIGH
}

enum PreferredContactMethod {
  PHONE
  EMAIL
}

model User {
  id                  String     @id @default(uuid()) @db.Uuid
  /// Must be stored in normalized lowercase form by the future identity service.
  email               String     @unique @db.VarChar(320)
  passwordHash        String     @map("password_hash")
  displayName         String     @map("display_name")
  role                StaffRole
  status              UserStatus @default(ACTIVE)
  lastLoginAt         DateTime?  @map("last_login_at") @db.Timestamptz(3)
  failedLoginAttempts Int        @default(0) @map("failed_login_attempts")
  lockedUntil         DateTime?  @map("locked_until") @db.Timestamptz(3)
  passwordChangedAt   DateTime?  @map("password_changed_at") @db.Timestamptz(3)
  createdAt           DateTime   @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt           DateTime   @updatedAt @map("updated_at") @db.Timestamptz(3)

  assignedIncidents     Incident[]                     @relation("IncidentAssignee")
  incidentStatusChanges IncidentStatusHistory[]        @relation("IncidentStatusChangedBy")
  assignmentsFrom       IncidentAssignmentHistory[]    @relation("IncidentAssignmentFromUser")
  assignmentsTo         IncidentAssignmentHistory[]    @relation("IncidentAssignmentToUser")
  assignmentChanges     IncidentAssignmentHistory[]    @relation("IncidentAssignmentChangedBy")
  contactAccesses       IncidentContactAccessHistory[]
  sessions              StaffSession[]

  @@index([role, status])
  @@map("staff_users")
}

model StaffSession {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  tokenHash  String    @unique @map("token_hash") @db.Char(64)
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  expiresAt  DateTime  @map("expires_at") @db.Timestamptz(3)
  lastUsedAt DateTime  @default(now()) @map("last_used_at") @db.Timestamptz(3)
  revokedAt  DateTime? @map("revoked_at") @db.Timestamptz(3)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([expiresAt, revokedAt])
  @@map("staff_sessions")
}

model IncidentCategory {
  id            String   @id @default(uuid()) @db.Uuid
  nameHa        String   @unique @map("name_ha") @db.VarChar(160)
  nameEn        String   @unique @map("name_en") @db.VarChar(160)
  descriptionHa String?  @map("description_ha") @db.VarChar(500)
  descriptionEn String?  @map("description_en") @db.VarChar(500)
  isActive      Boolean  @default(true) @map("is_active")
  displayOrder  Int      @default(0) @map("display_order")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  incidents Incident[]

  @@index([isActive, displayOrder])
  @@map("incident_categories")
}

model Incident {
  id                    String             @id @default(uuid()) @db.Uuid
  internalCaseId        String             @unique @map("internal_case_id") @db.VarChar(17)
  categoryId            String             @map("category_id") @db.Uuid
  description           String             @db.Text
  incidentDate          DateTime?          @map("incident_date") @db.Date
  incidentTime          DateTime?          @map("incident_time") @db.Time(0)
  locationDescription   String?            @map("location_description") @db.VarChar(500)
  state                 String?            @db.VarChar(100)
  lga                   String?            @db.VarChar(100)
  latitude              Decimal?           @db.Decimal(9, 6)
  longitude             Decimal?           @db.Decimal(10, 6)
  severity              IncidentSeverity
  status                IncidentStatus     @default(NEW)
  submissionLanguage    SubmissionLanguage @map("submission_language")
  assignedToUserId      String?            @map("assigned_to_user_id") @db.Uuid
  duplicateOfIncidentId String?            @map("duplicate_of_incident_id") @db.Uuid
  submittedAt           DateTime           @default(now()) @map("submitted_at") @db.Timestamptz(3)
  updatedAt             DateTime           @updatedAt @map("updated_at") @db.Timestamptz(3)
  closedAt              DateTime?          @map("closed_at") @db.Timestamptz(3)

  category             IncidentCategory               @relation(fields: [categoryId], references: [id])
  assignedToUser       User?                          @relation("IncidentAssignee", fields: [assignedToUserId], references: [id], onDelete: SetNull)
  duplicateOfIncident  Incident?                      @relation("IncidentDuplicates", fields: [duplicateOfIncidentId], references: [id], onDelete: SetNull)
  duplicates           Incident[]                     @relation("IncidentDuplicates")
  contact              IncidentContact?
  statusHistory        IncidentStatusHistory[]
  assignmentHistory    IncidentAssignmentHistory[]
  contactAccessHistory IncidentContactAccessHistory[]

  @@index([categoryId, status])
  @@index([status, severity, submittedAt])
  @@index([assignedToUserId])
  @@index([duplicateOfIncidentId])
  @@map("incidents")
}

model IncidentContact {
  id                      String                 @id @default(uuid()) @db.Uuid
  incidentId              String                 @unique @map("incident_id") @db.Uuid
  name                    String?                @db.Text
  phone                   String?                @db.Text
  email                   String?                @db.Text
  preferredContactMethod  PreferredContactMethod @map("preferred_contact_method")
  safeContactInstructions String?                @map("safe_contact_instructions") @db.Text
  consentToContact        Boolean                @map("consent_to_contact")
  createdAt               DateTime               @default(now()) @map("created_at") @db.Timestamptz(3)

  incident      Incident                       @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  accessHistory IncidentContactAccessHistory[]

  @@map("incident_contacts")
}

model IncidentStatusHistory {
  id              String          @id @default(uuid()) @db.Uuid
  incidentId      String          @map("incident_id") @db.Uuid
  fromStatus      IncidentStatus? @map("from_status")
  toStatus        IncidentStatus  @map("to_status")
  changedByUserId String?         @map("changed_by_user_id") @db.Uuid
  comment         String?         @db.VarChar(1000)
  createdAt       DateTime        @default(now()) @map("created_at") @db.Timestamptz(3)

  incident      Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  changedByUser User?    @relation("IncidentStatusChangedBy", fields: [changedByUserId], references: [id], onDelete: SetNull)

  @@index([incidentId, createdAt])
  @@index([changedByUserId])
  @@map("incident_status_history")
}

model IncidentAssignmentHistory {
  id              String   @id @default(uuid()) @db.Uuid
  incidentId      String   @map("incident_id") @db.Uuid
  fromUserId      String?  @map("from_user_id") @db.Uuid
  toUserId        String?  @map("to_user_id") @db.Uuid
  changedByUserId String   @map("changed_by_user_id") @db.Uuid
  comment         String?  @db.VarChar(1000)
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  incident      Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  fromUser      User?    @relation("IncidentAssignmentFromUser", fields: [fromUserId], references: [id], onDelete: SetNull)
  toUser        User?    @relation("IncidentAssignmentToUser", fields: [toUserId], references: [id], onDelete: SetNull)
  changedByUser User     @relation("IncidentAssignmentChangedBy", fields: [changedByUserId], references: [id], onDelete: Restrict)

  @@index([incidentId, createdAt])
  @@index([fromUserId])
  @@index([toUserId])
  @@index([changedByUserId])
  @@map("incident_assignment_history")
}

model IncidentContactAccessHistory {
  id               String   @id @default(uuid()) @db.Uuid
  incidentId       String   @map("incident_id") @db.Uuid
  contactId        String   @map("contact_id") @db.Uuid
  accessedByUserId String   @map("accessed_by_user_id") @db.Uuid
  reason           String   @db.VarChar(1000)
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  incident   Incident        @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  contact    IncidentContact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  accessedBy User            @relation(fields: [accessedByUserId], references: [id], onDelete: Restrict)

  @@index([incidentId, createdAt])
  @@index([accessedByUserId, createdAt])
  @@map("incident_contact_access_history")
}
