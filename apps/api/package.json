{
  "name": "@garkuwa/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "start": "node dist/main.js",
    "lint": "eslint src test scripts prisma.config.ts",
    "typecheck": "tsc --noEmit",
    "test": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --runInBand",
    "db:generate": "prisma generate",
    "db:migrate": "node ./scripts/prisma-with-db-check.mjs migrate dev",
    "db:status": "node ./scripts/prisma-with-db-check.mjs migrate status",
    "db:studio": "prisma studio",
    "db:verify": "node ./scripts/verify-db.mjs",
    "staff:set-password": "node --loader ts-node/esm ./scripts/set-staff-password.ts"
  },
  "dependencies": {
    "@nestjs/common": "11.1.28",
    "@nestjs/core": "11.1.28",
    "@nestjs/platform-express": "11.1.28",
    "@prisma/adapter-pg": "7.9.0",
    "@prisma/client": "7.9.0",
    "argon2": "^0.45.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "dotenv": "17.2.3",
    "pg": "8.22.0",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@garkuwa/config": "workspace:*",
    "@jest/globals": "30.2.0",
    "@nestjs/cli": "11.0.16",
    "@nestjs/testing": "11.1.28",
    "@types/jest": "30.0.0",
    "@types/node": "24.10.4",
    "@types/pg": "8.15.6",
    "@types/supertest": "6.0.3",
    "eslint": "9.39.1",
    "jest": "30.2.0",
    "prisma": "7.9.0",
    "supertest": "7.1.4",
    "ts-jest": "29.4.6",
    "ts-node": "10.9.2",
    "typescript": "5.9.3"
  }
}
